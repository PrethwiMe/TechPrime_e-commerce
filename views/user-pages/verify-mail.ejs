<%- include('partials/header')  %>
<div class="forgot-password-container" style="max-width: 600px; margin: 100px auto; padding: 40px;">
  <h2 style="font-size: 28px; font-weight: 600; margin-bottom: 10px;">Enter OTP ?</h2>
  <p style="margin-bottom: 30px;">Mail Sent to your registered email</p>

  <% if (error) { %>
    <div style="color: red; margin-bottom: 20px;"><%= error %></div>
  <% } %>

  <form action="/veryfyOTP" method="POST" style="display: flex; gap: 10px; margin-bottom: 30px;">
    <input 
      type="number" 
      name="otp" 
      placeholder="Enter your OTP" 
      required 
      style="flex: 1; padding: 12px; border: none; border-bottom: 1px solid #ccc; font-size: 16px;"
    >
    <a href="/resend-otp"><button type="submit" name="resend" value="1" style="background: black; color: white; border: none; padding: 12px 20px; cursor: pointer;">
      Resend OTP
    </button></a>
  </form>
  

  <div style="display: flex; justify-content: space-between;">
    <a href="/login" style="color: black; text-decoration: none;">Back to Login</a>
    <button 
      type="submit" 
      form="verifyForm" 
      style="background: black; color: white; border: none; padding: 12px 30px; cursor: pointer;"
    >
      Verify Email
    </button>
  </div>

  <!-- Hidden form to handle verify -->
  <form id="verifyForm" action="/verify-email" method="POST" style="display: none;">
    <input type="hidden" name="email" value="">
  </form>
</div>
<%- include('partials/footer')  %>