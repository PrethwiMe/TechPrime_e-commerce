<%- include('partials/header')  %>
<link rel="stylesheet" href="/stylesheets/vrifyUser.css">


<div class="forgot-password-container" style="max-width: 600px; margin: 100px auto; padding: 40px;">
  <h2 style="font-size: 28px; font-weight: 600; margin-bottom: 10px;">Enter OTP ?</h2>
  <p style="margin-bottom: 30px;">Mail Sent to your registered email</p>

  <% if (error) { %>
    <div style="color: red; margin-bottom: 20px;"><%= error %></div>
  <% } %>

  <form action="/veryfyOTP" method="POST" style="display: flex; gap: 10px; margin-bottom: 30px;">
    <input 
      type="text" 
      name="otp" 
      placeholder="Enter your OTP" 
      required 
      style="flex: 1; padding: 12px; border: none; border-bottom: 1px solid #ccc; font-size: 16px;"
    >

    <button type="button" 
      id="resendOtpBtn"
      data-email="<%= userMail %>" 
      style="background: black; color: white; border: none; padding: 12px 20px; cursor: pointer;"
    >
      Resend OTP
    </button>
  </form>

  <span id="resendStatus" style="margin-top: -20px; display: block; font-size: 14px;"></span>

  <div style="display: flex; justify-content: space-between; margin-top: 1%;">
    <a href="/login" style="color: black; text-decoration: none;">Back to Login</a>
    <button 
      type="submit" 
      form="verifyForm" 
      style="background: black; color: white; border: none; padding: 12px 30px; cursor: pointer;"
    >
      Verify Email
    </button>
  </div>

  <!-- Hidden form to handle verify -->
  <form id="verifyForm" action="/verify-email" method="POST" style="display: none;">
    <input type="hidden" name="email" value="<%= userMail %>">
  </form>
</div>

<script>
  document.getElementById('resendOtpBtn').addEventListener('click', async () => {
    const statusSpan = document.getElementById('resendStatus');
    const email = document.getElementById('resendOtpBtn').dataset.email;

    statusSpan.style.color = 'black';
    statusSpan.textContent = 'Sending...';

    try {
      const response = await fetch('/resend-otp', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email })  // Send the email to the backend
      });

      const result = await response.json();

      if (result.success) {
        statusSpan.style.color = 'green';
        statusSpan.textContent = '✅ OTP resent successfully!';
      } else {
        statusSpan.style.color = 'red';
        statusSpan.textContent = '❌ ' + (result.error || 'Failed to resend OTP.');
      }
    } catch (err) {
      statusSpan.style.color = 'red';
      statusSpan.textContent = '❌ Server error';
    }
  });
</script>

<%- include('partials/footer')  %>
