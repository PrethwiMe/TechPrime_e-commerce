<%- include('partials/header') %>
<link rel="stylesheet" href="/stylesheets/style.css">


<div class="container-fluid py-5 px-5">
  <div class="row d-flex align-items-center">
    <div class="col-lg-6 mb-4">
      <img src="/images/image.png" alt="Rocket" class="img-fluid rounded-4 shadow">
    </div>

    <div class="col-lg-6 px-5">
      <h2 class="fw-bold">Create an account</h2>
      <p class="text-muted mb-4">Enter your details below</p>

      <form action="/signupData" method="POST">
        <div class="row">
          <div class="col">
            <input type="text" name="firstName" class="form-control underline-input mb-3" placeholder="First Name" required>
          </div>
          <div class="col">
            <input type="text" name="lastName" class="form-control underline-input mb-3" placeholder="Last Name" required>
          </div>
        </div>

        <input type="text" name="phone" class="form-control underline-input mb-3" placeholder="Phone" required>
        <input type="email" name="email" class="form-control underline-input mb-3" placeholder="Email" required>
        <input type="password" name="password" class="form-control underline-input mb-3" placeholder="Password" required>
        <input type="password" name="confirmPassword" class="form-control underline-input mb-3" placeholder="Confirm Password" required>
        <input type="text" name="referralCode" class="form-control underline-input mb-4" placeholder="Enter referral code (optional)">
       <% if (error && error.length > 0) { %>
  <p style="color: red;"><%= error %></p>
<% } %>
        <button type="submit" class="btn btn-dark w-100 mb-3 py-2 mt-3">Create Account</button>

        <button type="button" class="btn btn-outline-secondary w-100 mb-3 py-2 d-flex align-items-center justify-content-center gap-2">
          <img src="https://img.icons8.com/color/24/000000/google-logo.png" />
          Sign up with Google
        </button>

        <div class="text-center">
          Already have an account? <a href="/login" class="text-decoration-underline">Log in</a>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
